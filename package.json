{
  "name": "haven-space",
  "version": "1.0.0",
  "description": "Boarding house rental platform connecting boarders with verified landlords in the Philippines",
  "main": "index.js",
  "scripts": {
    "server": "cd server && php -S localhost:8000 router.php",
    "client": "cd client && python -m http.server 3000",
    "mysql": "docker run --name haven-mysql -e MYSQL_ROOT_PASSWORD=root -e MYSQL_DATABASE=haven_space -p 3306:3306 -d mysql:8.0",
    "db:setup": "php scripts/setup-database.php",
    "db:reset": "php scripts/reset-database.php",
    "db:reset:force": "php scripts/reset-database.php --force",
    "fix:rooms": "cd server && php ../scripts/fix-room-data.php",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint client/js --ext .js",
    "lint:fix": "eslint --fix client/js --ext .js",
    "build": "node scripts/build.js",
    "prepare": "husky install"
  },
  "keywords": [
    "boarding-house",
    "rental",
    "philippines",
    "property-management"
  ],
  "author": "Haven Space Team",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^17.6.5",
    "@commitlint/config-conventional": "^17.6.5",
    "eslint": "^8.42.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "prettier": "^2.8.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,scss,md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
