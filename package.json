{
  "name": "haven-space",
  "version": "1.0.0",
  "type": "module",
  "description": "Boarding house rental platform connecting boarders with verified landlords in the Philippines",
  "main": "index.js",
  "scripts": {
    "server": "cd functions && php -S localhost:8000 router.php",
    "db:setup": "php scripts/setup-database.php",
    "db:reset": "php scripts/reset-database.php",
    "db:reset:force": "php scripts/reset-database.php --force",
    "appwrite:setup": "node scripts/appwrite-setup.js",
    "appwrite:setup:dry": "node scripts/appwrite-setup.js --dry-run",
    "appwrite:reset": "node scripts/appwrite-setup.js --reset",
    "appwrite:test": "node scripts/test-appwrite.js",
    "appwrite:migrate": "node scripts/appwrite-migrate.js",
    "appwrite:migrate:status": "node scripts/appwrite-migrate.js --status",
    "env:local": "cd server && php scripts/deploy.php local",
    "env:prod": "cd server && php scripts/deploy.php production",
    "env:status": "cd server && php scripts/env-status.php",
    "env:test": "curl -s https://haven-space.appwrite.network/api/test-environment.php | jq .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint client/js --ext .js",
    "lint:fix": "eslint --fix client/js --ext .js",
    "build": "node scripts/build.js",
    "prepare": "husky install"
  },
  "keywords": [
    "boarding-house",
    "rental",
    "philippines",
    "property-management"
  ],
  "author": "Haven Space Team",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^17.6.5",
    "@commitlint/config-conventional": "^17.6.5",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "prettier": "^2.8.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,scss,md,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "appwrite": "^24.2.0",
    "node-appwrite": "^14.1.0"
  }
}
