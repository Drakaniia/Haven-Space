{
  "name": "havenspace/server",
  "description": "Haven Space Boarding House Platform - Backend API",
  "type": "project",
  "license": "MIT",
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.0",
    "appwrite/appwrite": "13.0",
    "firebase/php-jwt": "^7.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "codeception/codeception": "^5.3",
    "codeception/module-phpbrowser": "^4.0",
    "codeception/module-rest": "^3.4",
    "phpstan/phpstan": "1.10",
    "phpunit/phpunit": "^9.0",
    "codeception/module-asserts": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "test:codeception": "vendor/bin/codecept run",
    "test:api": "vendor/bin/codecept run api",
    "analyze": "phpstan analyse"
  }
}
