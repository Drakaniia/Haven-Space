# Application Environment
# Change this to 'production' when deploying
APP_ENV=local
APP_DEBUG=true

# Database Configuration
# LOCAL (XAMPP) - Use these for local development
DB_HOST=localhost
DB_PORT=3306
DB_NAME=havenspace_db
DB_USER=root
DB_PASS=

# PRODUCTION - Uncomment and use these for production
# DB_HOST=your_production_host
# DB_PORT=3306
# DB_NAME=havenspace_production_db
# DB_USER=your_production_user
# DB_PASS=your_production_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://haven-space.appwrite.network/api/auth/google/callback.php

# Application Base URL
APP_BASE_URL=https://haven-space.appwrite.network

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://haven-space.appwrite.network,http://localhost:3000,http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000

# Appwrite Configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here
APPWRITE_DATABASE_ID=your_database_id_here

# Groq AI Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile